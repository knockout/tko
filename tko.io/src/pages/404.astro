<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | TKO</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Manrope, system-ui, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(46, 99, 218, 0.16), transparent 30rem),
          #f8fafc;
        color: #0f172a;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
      }

      main {
        max-width: 36rem;
        padding: 2rem;
        border: 1px solid rgba(46, 99, 218, 0.14);
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.9);
        box-shadow: 0 24px 60px -32px rgba(15, 23, 42, 0.35);
      }

      h1 {
        margin: 0 0 0.75rem;
        font-size: clamp(2.2rem, 4vw, 3rem);
        letter-spacing: -0.04em;
      }

      p {
        margin: 0 0 1rem;
        line-height: 1.7;
      }

      a {
        color: #1d4ed8;
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Page Not Found</h1>
      <p>The page you requested does not exist in this TKO documentation build.</p>
      <p><a href="/">Return to the introduction</a></p>
    </main>
  </body>
</html>
