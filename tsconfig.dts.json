{
  "extends": "./tsconfig.json",
  "compilerOptions": {   
    "noEmit": false,
    "rootDir": ".",
    "emitDeclarationOnly": true,
    "verbatimModuleSyntax": null,
    "outDir": "dist",
    "resolvePackageJsonExports": false,
    "resolvePackageJsonImports": false
  },
  "exclude": [
    "node_modules",
    "builds/knockout",
    "docs",
    "tools",
    "**/spec/**",
    "tko.io"
  ]
}
