{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "./.dts-tmp/emit"
  },
  "include": [
    "global.d.ts",
    "packages/*/src/**/*.ts",
    "builds/reference/src/**/*.ts",
    "builds/knockout/src/**/*.ts"
  ],
  "exclude": [
    "packages/*/src/**/*.d.ts",
    "builds/reference/src/**/*.d.ts",
    "builds/knockout/src/**/*.d.ts",
    "**/spec/**",
    "node_modules",
    "tko.io",
    "tools"
  ]
}
